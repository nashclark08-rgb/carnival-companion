rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /carnivals/{carnivalId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /events/{eventId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      match /announcements/{announcementId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}
